{
  "name": "takoyaki",
  "version": "0.1.0",
  "description": "takoyaki backend API",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "build": "npx prisma generate && npx tsc",
    "start": "node dist/index.js",
    "start:prod": "prisma migrate deploy && node dist/index.js",
    "prod": "concurrently \"npx tsc --watch\" \"nodemon -q dist/index.js\"",
    "dev": "cross-env NODE_ENV=development nodemon index.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "migrate:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlsatina/takoyaki-pos.git"
  },
  "keywords": [
    "HealthRecords"
  ],
  "author": "RC Satina",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/carlsatina/takoyaki-pos/issues"
  },
  "homepage": "https://github.com/carlsatina/takoyaki-pos#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@types/multer": "^2.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fs": "^0.0.1-security",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pg": "^8.11.3",
    "@deadendjs/swagger-jsdoc": "^8.0.1",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.18",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/node": "^20.8.2",
    "@types/pg": "^8.10.3",
    "@types/swagger-ui-express": "^4.1.6",
    "concurrently": "^8.2.1",
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.1",
    "prisma": "^7.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2"
  }
}
